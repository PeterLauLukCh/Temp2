# Normalize all text files to LF in the repo and on checkout.
* text=auto eol=lf

# Treat known binary types as binary (never normalize).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.whl  binary
*.gz   binary
*.zip  binary
*.so   binary
*.npy  binary
*.npz  binary
*.pt   binary
*.pth  binary
*.pkl  binary
